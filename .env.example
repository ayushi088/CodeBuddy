# StudyBuddy environment variables (local development)

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/studybuddy
# Set true when using hosted Postgres that requires TLS (e.g., Render)
DATABASE_SSL=false
DATABASE_CONNECT_TIMEOUT_MS=12000
DATABASE_QUERY_RETRY_COUNT=1
DATABASE_POOL_MAX=10

# Python AI engine endpoint
AI_ENGINE_URL=http://localhost:8000

# Public app URL used in emails/links
APP_URL=http://localhost:3000

# Next.js server port
PORT=3000

# Brevo email integration (optional for local dev)
BREVO_API_KEY=
FROM_EMAIL=noreply@studybuddy.app
FROM_NAME=Study Buddy

# Optional: Cloudinary unsigned upload config for timetable files
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
